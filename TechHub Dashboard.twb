            <column caption='Profit Amount' datatype='real' name='[Calculation_2537993555615749]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[revenue] - ([cost_price] * [quantity])' />
            </column>
            <column caption='Profit Margin %' datatype='real' default-format='p0.00%' name='[Calculation_2537993558298631]' role='measure' type='quantitative'>
