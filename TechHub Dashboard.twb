      <aliases enabled='yes' />
      <column caption='Null check' datatype='string' name='[Calculation_2537993320845315]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([customer_id]) OR ISNULL([product_id]) OR ISNULL([order_date]) &#13;&#10;THEN &quot;MISSING&quot; &#13;&#10;ELSE &quot;OK&quot; &#13;&#10;END' />
      </column>
      <column caption='Profit Amount' datatype='real' name='[Calculation_2537993555615749]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[revenue] - ([cost_price] * [quantity])' />
      </column>
      <column caption='Profit Margin %' datatype='real' default-format='p0.00%' name='[Calculation_2537993558298631]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_2537993555615749] / [revenue]) * 100' />
      </column>
      <column aggregation='Avg' caption='Customer Tenure Days' datatype='integer' name='[Calculation_2537993565773832]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [signup_date], TODAY())' />
      </column>
      <column caption='Customer Lifetime Value' datatype='real' name='[Calculation_2537993567371273]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : SUM([revenue]) }' />
      </column>
      <column caption='Churn Rate' datatype='real' datatype-customized='true' name='[Calculation_2537993690255370]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='FLOAT(IF DATEDIFF(&apos;day&apos;, [signup_date], TODAY()) &gt; 365 &#13;&#10;THEN 1 &#13;&#10;ELSE 0 &#13;&#10;END)' />
      </column>
      <column caption='Avg Order Value' datatype='real' name='[Calculation_2537993693343755]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue]) / COUNTD([order_date])' />
      </column>
      <column caption='One' datatype='integer' name='[Calculation_2537994035544076]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Total Customers' datatype='integer' name='[Calculation_2537994037522445]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id])' />
      </column>
      <column caption='Customer Acquisition Rate' datatype='real' name='[Calculation_2537994038222862]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id]) / DATEDIFF(&apos;month&apos;, MIN([signup_date]), TODAY())' />
      </column>
      <column caption='Top Customer Segment' datatype='real' name='[Calculation_2537994038579215]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [loyalty_tier]: SUM([revenue])}' />
      </column>
      <column caption='Rev per Customer' datatype='real' name='[Calculation_2537994390425618]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue]) / COUNTD([customer_id])' />
      </column>
